# KNN CLASSIFICATION ON SYNTHETIC DATA WITH VARYING K VALUES

# AIM:
# To implement the k-Nearest Neighbor (KNN) algorithm to classify
# randomly generated data points and analyze the effect of
# different values of K on classification performance.

# Import libraries
import numpy as np
import matplotlib.pyplot as plt
from collections import Counter

# Generate random data
np.random.seed(42)

data = np.random.rand(100)

# Assign labels
labels = ["Class1" if x <= 0.5 else "Class2" for x in data]

# Split into training and testing data
train_data = data[:80]
train_labels = labels[:80]

test_data = data[80:]
test_labels = labels[80:]

# Function to compute Euclidean distance
def euclidean_distance(x1, x2):
    return abs(x1 - x2)

# KNN classifier function
def knn_classifier(train_data, train_labels, test_point, k):

    # Calculate distances
    distances = [
        (euclidean_distance(test_point, train_data[i]), train_labels[i])
        for i in range(len(train_data))
    ]

    # Sort by distance
    distances.sort(key=lambda x: x[0])

    # Get k nearest neighbors
    k_neighbors = distances[:k]

    # Extract labels
    k_neighbor_labels = [label for _, label in k_neighbors]

    # Majority voting
    predicted_label = Counter(k_neighbor_labels).most_common(1)[0][0]

    return predicted_label

# Test different K values
k_values = [1, 3, 5, 7]

for k in k_values:

    correct = 0

    print(f"\nResults for K = {k}")

    for i in range(len(test_data)):

        prediction = knn_classifier(
            train_data,
            train_labels,
            test_data[i],
            k
        )

        print(
            f"Test Point: {test_data[i]:.2f} "
            f"Actual: {test_labels[i]} "
            f"Predicted: {prediction}"
        )

        if prediction == test_labels[i]:
            correct += 1

    accuracy = (correct / len(test_data)) * 100

    print(f"Accuracy for K = {k}: {accuracy:.2f}%")

# Plot the data
plt.figure(figsize=(8, 5))

for i in range(len(data)):
    if labels[i] == "Class1":
        plt.scatter(data[i], 1, color='blue')
    else:
        plt.scatter(data[i], 2, color='red')

plt.yticks([1, 2], ["Class1", "Class2"])

plt.xlabel("Data Value")
plt.ylabel("Class")
plt.title("Synthetic Data Classification using KNN")

plt.grid(True)
plt.show()
